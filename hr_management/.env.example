# Copy this file to .env (same folder) and fill in your values.
# The app loads it automatically from hr_management/.env.

# REQUIRED — Google Gemini API key. Get one free at https://aistudio.google.com/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# Optional — Gemini model to use (default: gemini-2.5-flash)
# GEMINI_MODEL=gemini-2.5-flash

# Optional — MongoDB connection string for storing candidates.
# Leave unset to run without a database (everything else still works).
# MONGODB_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/?retryWrites=true&w=majority
# MONGODB_DB_NAME=resume_screening
# MONGODB_COLLECTION=candidates

# Optional — seconds to pause between Gemini calls (set to 4 if you hit
# free-tier rate limits). Default: 0
# GEMINI_REQUEST_DELAY=0
